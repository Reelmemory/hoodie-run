# Wallet that deploys and owns the GameRewards contract (needs Robinhood Chain ETH for gas)
DEPLOYER_PRIVATE_KEY=6e5d1b93b1401318f678e650728116bcd56d3bba282df03b7f427fe98e6fa791

# HOODIE's verified contract address (confirmed via Bankr/creator, on Robinhood Chain)
MEMECOIN_ADDRESS=0xC72c01AAB5f5678dc1d6f5C6d2B417d91D402Ba3

# Address of the DISTRIBUTOR wallet (see backend/.env — the matching private
# key goes there as DISTRIBUTOR_PRIVATE_KEY). This is the wallet the backend
# uses to send reward payouts, so it only ever needs ETH for gas.
DISTRIBUTOR_ADDRESS=0x40B11c4A46aE4E2dFC667c68209B6bEaf02b41F1

# Robinhood Chain mainnet (chainId 4663) — where HOODIE actually lives.
# Public RPC is rate-limited; use a provider (QuickNode/Blockdaemon/dRPC/
# Validation Cloud) for production.
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Kept for reference if you ever deploy a version on Ethereum mainnet instead
MAINNET_RPC_URL=https://eth.llamarpc.com
ETHERSCAN_API_KEY=
