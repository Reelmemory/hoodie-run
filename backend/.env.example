# RPC endpoint — Robinhood Chain mainnet (chainId 4663), where HOODIE lives.
# Public endpoint is rate-limited; use a provider for production (see the
# Robinhood Chain docs: QuickNode/Blockdaemon/dRPC/Validation Cloud).
RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Address of the deployed GameRewards contract
REWARDS_CONTRACT_ADDRESS=0xYourGameRewardsAddress

# Private key of the DISTRIBUTOR wallet — this is the wallet that actually
# sends the on-chain distributeReward() transaction and pays its own gas.
# Fund it with a modest amount of ETH for gas only; it should never hold the
# memecoin itself (the GameRewards contract holds the reserve).
# This address must match `distributor` set in the GameRewards contract.
DISTRIBUTOR_PRIVATE_KEY=0xyourprivatekey

# Skip on-chain distribution (and its gas cost) below this score.
MIN_SCORE_FOR_REWARD=30

# How often queued rewards are flushed into one distributeBatch transaction,
# and the max players paid per batch (must stay <= the contract's
# MAX_BATCH_SIZE of 150). Default is short (15s) so it feels near-instant to
# players while still batching anyone who finishes around the same time.
# Raise this if gas costs matter more to you than payout speed.
BATCH_INTERVAL_MS=15000
MAX_BATCH_SIZE=100

PORT=4000
